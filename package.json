{
  "name": "@vidwadeseram/auth-ui-shared",
  "version": "0.1.0",
  "description": "Shared API client, Zod types, and auth hooks for auth template frontends",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "generate-schema": "./dist/cli/generate-schema.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate:schema": "node dist/cli/generate-schema.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "openapi-zod-client": "^0.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.5",
    "react": "^19.2.5"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}